{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "travelers_backpack:oak_wood_backpack_item",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/travelers_backpack/common/backpacks/backpack_log"
      },
      "geometry": {
        "default": "geometry.travelers_bp_backpack_default"
      },
      "animations": {
        "first_person": "animation.travelers_backpack.backpack.first_person",
        "third_person": "animation.travelers_backpack.backpack.third_person",
        "equipped": "animation.travelers_backpack.backpack.equipped"
      },
      "scripts": {
        "animate": [
          {
            "third_person": "c.item_slot == 'main_hand' && !c.is_first_person"
          },
          {
            "first_person": "c.item_slot == 'main_hand' && c.is_first_person"
          },
          {
            "equipped": "c.item_slot != 'main_hand' && !c.is_first_person"
          }
        ]
      },
      "render_controllers": [
        "controller.render.travelers_backpack.backpack"
      ]
    }
  }
}