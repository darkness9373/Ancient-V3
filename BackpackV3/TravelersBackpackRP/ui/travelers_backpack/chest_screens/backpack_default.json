    "type": "image",
    "size": [
      16,
      16
    ],
    "offset": [
      "100%",
      "100%"
    ],
    "tiled": "y",
    "anchor_from": "center",
    "anchor_to": "center",
    "uv_size": [
      16,
      16
    ],
    "uv": "@travelers_backpack_default.liquid_flip_book",
    "clip_direction": "up",
    "clip_ratio": 0.00,
    "texture": "#texture",
    "property_bag": {
      "#require": "b0.00"
    },
    "bindings": [
      {
        "binding_name": "#hover_text",
        "binding_type": "collection",
        "binding_condition": "always",
        "binding_collection_name": "container_items"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#hover_text - '§f§o' - '§r§r§r'))",
        "binding_condition": "visibility_changed",
        "target_property_name": "#hover_fixed"
      },
      {
        "binding_type": "view",
        "source_property_name": "(('%.5s' * #hover_fixed))",
        "binding_condition": "visibility_changed",
        "target_property_name": "#bar_percent"
      },
      {
        "binding_type": "view",
        "source_property_name": "('textures/travelers_backpack/common/gui/liquids/'+(#hover_fixed - #bar_percent))",
        "target_property_name": "#texture"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#bar_percent = #require)",
        "target_property_name": "#visible"
      }
    ]
  },
