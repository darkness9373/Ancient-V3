{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "je:rgb",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 20,
				"max_particles": 200
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 2.2
			},
			"minecraft:emitter_shape_point": {
				"offset": ["1.1*-math.sin(variable.emitter_age*180)", 2.5, "1.1*math.cos(variable.emitter_age*180)"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "1.2 / math.random(0.2, 1.0)"
			},
			"minecraft:particle_initial_speed": 0,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, -4, 0]
			},
			"minecraft:particle_appearance_billboard": {
				"size": ["variable.particle_random_3 * 0.075 + 0.075", "variable.particle_random_3 * 0.075 + 0.075"],
				"facing_camera_mode": "lookat_xyz",
				"uv": {
					"texture_width": 128,
					"texture_height": 128,
					"flipbook": {
						"base_UV": [0, 96],
						"size_UV": [8, 8],
						"step_UV": [8, 0],
						"frames_per_second": 8,
						"max_frame": 8,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_motion_collision": {
				"coefficient_of_restitution": 0.27,
				"collision_radius": 0.1
			},
			"minecraft:particle_appearance_lighting": {},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFD30000",
						"0.12": "#FFFF5300",
						"0.26": "#FFFFF123",
						"0.42": "#FF00F607",
						"0.56": "#FF00FFDD",
						"0.71": "#FF1A19FF",
						"0.86": "#FFB000D2",
						"1.0": "#FFD50051"
					}
				}
			}
		}
	}
}